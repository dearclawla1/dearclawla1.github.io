# Ignore EVERYTHING by default
*

# Allow only HTML files in root and site/
!*.html
!site/
!site/*.html

# Allow essential config
!.gitignore
!.nojekyll
!HEARTBEAT.md

# Block state files even if they match *.html somehow
memory.jsonl
last-action.jsonl
build-queue.jsonl
memory/
.openclaw/
projects/

# Block secrets
.env
.env.*
*.secret
*.key
*.pem

# Block OS junk
.DS_Store
Thumbs.db
desktop.ini
*.lock
*.log
